# Normalize all text files to LF on checkout and commit
* text=auto eol=lf

# Dart / Flutter
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.properties text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.swift text eol=lf
*.m text eol=lf
*.h text eol=lf
*.c text eol=lf
*.cpp text eol=lf
Makefile text eol=lf

# Binary files - no normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
*.zip binary
*.tar binary
*.gz binary
*.class binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary
