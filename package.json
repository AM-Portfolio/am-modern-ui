{
  "name": "am-modern-ui",
  "version": "1.0.0",
  "description": "AM Investment Platform - Modern UI Task Runner",
  "scripts": {
    "manage": "python scripts/manage.py",
    "run:app": "npm run run:app:local",
    "run:app:9000": "cd am_app && flutter run -d chrome --web-port=9000 --no-web-resources-cdn --web-launch-url=http://localhost:9000/login --dart-define=AM_ENV=local",
    "run:auth": "npm run run:auth:local",
    "run:trade": "npm run run:trade:local",
    "run:portfolio": "npm run run:portfolio:local",
    "run:market": "npm run run:market:local",
    "run:diagnostic": "npm run run:diagnostic:local",
    "run:subscription": "npm run run:subscription:local",
    "build:app": "npm run build:app:local",
    "─── RUN LOCAL (boot trace ON by default) ───": "echo",
    "run:app:local": "python scripts/manage.py run app local --boot-trace",
    "run:auth:local": "python scripts/manage.py run auth local --boot-trace",
    "run:trade:local": "python scripts/manage.py run trade local --boot-trace",
    "run:portfolio:local": "python scripts/manage.py run portfolio local --boot-trace",
    "run:market:local": "python scripts/manage.py run market local --boot-trace",
    "run:diagnostic:local": "python scripts/manage.py run diagnostic local --boot-trace",
    "run:subscription:local": "python scripts/manage.py run subscription local --boot-trace",
    "run:app:local:notrace": "python scripts/manage.py run app local --no-boot-trace",
    "─── RUN DEV ───": "echo",
    "run:app:dev": "python scripts/manage.py run app dev --boot-trace",
    "run:auth:dev": "python scripts/manage.py run auth dev --boot-trace",
    "run:trade:dev": "python scripts/manage.py run trade dev --boot-trace",
    "run:portfolio:dev": "python scripts/manage.py run portfolio dev --boot-trace",
    "run:market:dev": "python scripts/manage.py run market dev --boot-trace",
    "run:diagnostic:dev": "python scripts/manage.py run diagnostic dev --boot-trace",
    "run:subscription:dev": "python scripts/manage.py run subscription dev --boot-trace",
    "─── RUN PREPROD ───": "echo",
    "run:app:preprod": "python scripts/manage.py run app preprod --boot-trace",
    "run:auth:preprod": "python scripts/manage.py run auth preprod --boot-trace",
    "run:trade:preprod": "python scripts/manage.py run trade preprod --boot-trace",
    "run:portfolio:preprod": "python scripts/manage.py run portfolio preprod --boot-trace",
    "run:market:preprod": "python scripts/manage.py run market preprod --boot-trace",
    "run:diagnostic:preprod": "python scripts/manage.py run diagnostic preprod --boot-trace",
    "run:subscription:preprod": "python scripts/manage.py run subscription preprod --boot-trace",
    "─── RUN PROD ───": "echo",
    "run:app:prod": "python scripts/manage.py run app prod --boot-trace",
    "run:auth:prod": "python scripts/manage.py run auth prod --boot-trace",
    "run:trade:prod": "python scripts/manage.py run trade prod --boot-trace",
    "run:portfolio:prod": "python scripts/manage.py run portfolio prod --boot-trace",
    "run:market:prod": "python scripts/manage.py run market prod --boot-trace",
    "run:diagnostic:prod": "python scripts/manage.py run diagnostic prod --boot-trace",
    "run:subscription:prod": "python scripts/manage.py run subscription prod --boot-trace",
    "─── BUILD LOCAL ───": "echo",
    "build:app:local": "python scripts/manage.py build app local",
    "build:auth:local": "python scripts/manage.py build auth local",
    "build:trade:local": "python scripts/manage.py build trade local",
    "build:portfolio:local": "python scripts/manage.py build portfolio local",
    "build:market:local": "python scripts/manage.py build market local",
    "build:subscription:local": "python scripts/manage.py build subscription local",
    "build:app:local:trace": "python scripts/manage.py build app local --boot-trace",
    "─── BUILD DEV ───": "echo",
    "build:app:dev": "python scripts/manage.py build app dev",
    "build:auth:dev": "python scripts/manage.py build auth dev",
    "build:trade:dev": "python scripts/manage.py build trade dev",
    "build:portfolio:dev": "python scripts/manage.py build portfolio dev",
    "build:market:dev": "python scripts/manage.py build market dev",
    "build:subscription:dev": "python scripts/manage.py build subscription dev",
    "build:app:dev:trace": "python scripts/manage.py build app dev --boot-trace",
    "─── BUILD PREPROD (for Docker / cluster debugging) ───": "echo",
    "build:app:preprod": "python scripts/manage.py build app preprod",
    "build:auth:preprod": "python scripts/manage.py build auth preprod",
    "build:trade:preprod": "python scripts/manage.py build trade preprod",
    "build:portfolio:preprod": "python scripts/manage.py build portfolio preprod",
    "build:market:preprod": "python scripts/manage.py build market preprod",
    "build:subscription:preprod": "python scripts/manage.py build subscription preprod",
    "build:app:preprod:trace": "python scripts/manage.py build app preprod --boot-trace",
    "─── BUILD PROD ───": "echo",
    "build:app:prod": "python scripts/manage.py build app prod",
    "build:auth:prod": "python scripts/manage.py build auth prod",
    "build:trade:prod": "python scripts/manage.py build trade prod",
    "build:portfolio:prod": "python scripts/manage.py build portfolio prod",
    "build:market:prod": "python scripts/manage.py build market prod",
    "build:subscription:prod": "python scripts/manage.py build subscription prod",
    "build:app:prod:trace": "python scripts/manage.py build app prod --boot-trace",
    "─── GLOBAL UTILITIES ───": "echo",
    "clean:all": "python scripts/manage.py clean-all",
    "get:all": "python scripts/manage.py get-all",
    "gen:all": "python scripts/manage.py gen-all",
    "test:all": "python scripts/manage.py test-all",
    "test:auth:preprod": "python testing/run_auth.py preprod --open-report",
    "test:auth:local": "python testing/run_auth.py local --open-report",
    "test:auth:mcp": "echo Use: POST http://localhost:8120/api/v1/tools/ui-test/run-auth"
  },
  "author": "AsraX Tech",
  "license": "ISC"
}
