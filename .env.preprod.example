# AM Modern UI - Pre-Production Environment (Docker / CI build)
# Copied to /app/.env.preprod during docker build. Target host: am.asrax.in
# For local preprod runs: cp .env.preprod.example .env.preprod

AM_API_BASE_URL=https://am.asrax.in
AM_AUTH_BASE_URL=https://am.asrax.in/identity
AM_USER_BASE_URL=https://am.asrax.in/users
AM_PORTFOLIO_BASE_URL=https://am.asrax.in/portfolio
AM_TRADE_BASE_URL=https://am.asrax.in/trade
AM_MARKET_WS_URL=wss://am.asrax.in/market/ws/market-data-stream
AM_MARKET_BASE_URL=https://am.asrax.in/market
AM_ANALYSIS_BASE_URL=https://am.asrax.in/analysis
AM_GMAIL_BASE_URL=https://am.asrax.in/gmail

# Feature Flags
AM_USE_MOCK_DATA=false
AM_GOOGLE_CLIENT_ID=307768822337-ad7tee4d82cc0b4flgrfs157e5e6rc0g.apps.googleusercontent.com
FLUTTER_WEB_PORT=9000

AM_SUBSCRIPTION_BASE_URL=https://am.asrax.in/subscriptions
AM_DOMAIN=am.asrax.in
AM_ENV=preprod

# Boot telemetry — RUM on for all preprod users (no ?bootTrace=1 needed)
AM_BOOT_RUM=true
AM_BOOT_TRACE=false