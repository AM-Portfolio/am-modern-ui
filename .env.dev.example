# AM Modern UI - Dev Environment (Docker / CI build)
# Copied to /app/.env.preprod during docker build when TARGET_ENV=dev.
# Target host: am-dev.asrax.in

AM_API_BASE_URL=https://am-dev.asrax.in
AM_AUTH_BASE_URL=https://am-dev.asrax.in/identity
AM_USER_BASE_URL=https://am-dev.asrax.in/users
AM_PORTFOLIO_BASE_URL=https://am-dev.asrax.in/portfolio
AM_TRADE_BASE_URL=https://am-dev.asrax.in/trade
AM_MARKET_WS_URL=wss://am-dev.asrax.in/market/ws/market-data-stream
AM_MARKET_BASE_URL=https://am-dev.asrax.in/market
AM_ANALYSIS_BASE_URL=https://am-dev.asrax.in/analysis
AM_GMAIL_BASE_URL=https://am-dev.asrax.in/gmail

# Feature Flags
AM_USE_MOCK_DATA=false
AM_GOOGLE_CLIENT_ID=307768822337-ad7tee4d82cc0b4flgrfs157e5e6rc0g.apps.googleusercontent.com
FLUTTER_WEB_PORT=9000

AM_SUBSCRIPTION_BASE_URL=https://am-dev.asrax.in/subscriptions
