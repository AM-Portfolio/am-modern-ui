    <diagram id="phases" name="07 Implementation Phases">
        <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1000" background="#ffffff" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="ph" value="&lt;b&gt;Implementation Phases A–D&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;" parent="1" vertex="1">
                    <mxGeometry x="350" y="20" width="500" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="pa" value="&lt;b&gt;Phase A — Shell split&lt;/b&gt; (~1 day) HIGHEST IMPACT&lt;br&gt;&lt;br&gt;1. PortfolioSelectionScope → am_common&lt;br&gt;2. Remove GlobalPortfolioWrapper from app_shell&lt;br&gt;3. Defer PortfolioScreen in deferred_routes&lt;br&gt;4. Wrap Portfolio+Trade builders with wrapper inside chunk&lt;br&gt;&lt;br&gt;&lt;b&gt;Files:&lt;/b&gt; app_shell.dart · app_router.dart · deferred_routes.dart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#059669;fontColor=#fff;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="60" y="80" width="500" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="pb" value="&lt;b&gt;Phase B — Skeleton loaders&lt;/b&gt; (~0.5 day)&lt;br&gt;&lt;br&gt;1. skeleton param on DeferredModuleLoader&lt;br&gt;2. Market / Trade / Portfolio / Generic skeletons&lt;br&gt;3. Wire per-route in deferred_routes&lt;br&gt;&lt;br&gt;&lt;b&gt;Files:&lt;/b&gt; deferred_module_loader.dart · shell/skeletons/*.dart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4F46E5;fontColor=#fff;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="620" y="80" width="500" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="pc" value="&lt;b&gt;Phase C — Market layout&lt;/b&gt; (~0.5 day)&lt;br&gt;&lt;br&gt;1. Fix index card overflow (fixed heights)&lt;br&gt;2. Remove am_market_dev from MarketPage prod path&lt;br&gt;&lt;br&gt;&lt;b&gt;Files:&lt;/b&gt; dashboard_page.dart · index card widgets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F59E0B;fontColor=#fff;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="60" y="270" width="500" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="pd" value="&lt;b&gt;Phase D — Release verify&lt;/b&gt; (~0.5 day)&lt;br&gt;&lt;br&gt;1. npm run build:app:preprod:trace&lt;br&gt;2. Hard refresh /app/market/dashboard&lt;br&gt;3. Confirm: main + market part only&lt;br&gt;4. Document debug vs release in docs&lt;br&gt;&lt;br&gt;&lt;b&gt;Success:&lt;/b&gt; no portfolio/trade/ai part.js on market reload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#64748B;fontColor=#fff;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="620" y="270" width="500" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="di" value="&lt;b&gt;DI alignment&lt;/b&gt;&lt;br&gt;configureCoreDependencies: auth · theme · dashboard · STOMP&lt;br&gt;configureFeatureDependencies: subscription · MarketAnalysisService (lazy after Phase A)&lt;br&gt;PortfolioCubit: init inside deferred Portfolio/Trade chunk only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#4F46E5;align=left;spacingLeft=10;" parent="1" vertex="1">
