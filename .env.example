# AM Modern UI - Environment Configuration
# Use these variables with --dart-define in Flutter

# API Endpoints
AM_API_BASE_URL=http://localhost:8000
AM_AUTH_BASE_URL=http://localhost:8000/identity
AM_USER_BASE_URL=http://localhost:8000/users
AM_PORTFOLIO_BASE_URL=http://localhost:8000/portfolio
AM_TRADE_BASE_URL=http://localhost:8000/trade
AM_MARKET_BASE_URL=http://localhost:8000/market
# Deprecated: live prices use AM_WS_STREAM / wsStream via am-gateway STOMP
# AM_MARKET_WS_URL=ws://localhost:8000/market/ws/market-data-stream
AM_WS_STREAM=ws://localhost:8000/v1/streams
AM_ANALYSIS_BASE_URL=http://localhost:8000/analysis
AM_GMAIL_BASE_URL=http://localhost:8000/gmail

# Feature Flags & Developer Settings
AM_USE_MOCK_DATA=false
AM_GOOGLE_CLIENT_ID=your-google-client-id
AM_DEV_TOKEN=your-dev-token
AM_DEV_USER_ID=your-dev-user-id
FLUTTER_WEB_PORT=9000

# Boot performance tracing (startup timing in browser console)
# true = enable [BootTrace] logs; false = disable
# npm run scripts also support --boot-trace / --no-boot-trace flags
AM_BOOT_TRACE=true


AM_SUBSCRIPTION_BASE_URL=http://localhost:8110
